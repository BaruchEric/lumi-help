{
  "name": "@baruch-eric/lumi-help",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Embeddable in-app help center — symbol tooltips, learn mode, guides, and AI assist.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./adapters/storage": {
      "types": "./dist/adapters/storage.d.ts",
      "import": "./dist/adapters/storage.js"
    },
    "./adapters/transport": {
      "types": "./dist/adapters/transport.d.ts",
      "import": "./dist/adapters/transport.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "react",
    "help-center",
    "tooltip",
    "documentation",
    "ai",
    "learn-mode"
  ],
  "author": "Eric Baruch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BaruchEric/lumi-help.git"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
